---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="theme-wrapper">
      <header class="hero">
        <h1 class="hero-name">{pageTitle}</h1>
        <p class="hero-tagline">{tagline}</p>
        <div class="actions">
          {
            actions.map((action) => (
              <a
                href={action.link}
                class={`action-btn ${action.theme}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {action.text}
              </a>
            ))
          }
        </div>
      </header>

      <section class="features">
        <div class="features-grid">
          {
            features.map((feat) => (
              <div class="feature-card">
                <h3 class="feature-title">{feat.title}</h3>
                <p class="feature-details">{feat.details}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section class="section-container">
        <h2>Our Projects</h2>
        <div class="team-grid size-small">
          {
            projects.map((proj) => (
              <div class="member-card">
                <img src={proj.avatar} alt={proj.name} class="avatar" />
                <div class="info">
                  <h4 class="name">{proj.name}</h4>
                  <p class="title">{proj.title}</p>
                  <div class="links">
                    {proj.links.map((link) => (
                      <a
                        href={link.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={
                          typeof link.icon === "string" ? link.icon : "link"
                        }
                      >
                        <Fragment
                          set:html={
                            typeof link.icon === "string"
                              ? icon[link.icon]
                              : link.icon.svg
                          }
                        />
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="section-container">
        <h2>Our Team</h2>
        <div class="team-grid size-medium">
          {
            members.map((member) => (
              <div class="member-card">
                <img src={member.avatar} alt={member.name} class="avatar" />
                <div class="info">
                  <h4 class="name">{member.name}</h4>
                  <p class="title">{member.title}</p>
                  <div class="links">
                    {member.links.map((link) => (
                      <a
                        href={link.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={
                          typeof link.icon === "string" ? link.icon : "link"
                        }
                      >
                        <Fragment
                          set:html={
                            typeof link.icon === "string"
                              ? icon[link.icon]
                              : link.icon.svg
                          }
                        />
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </div>
    <div class="footer">
      <p>
        &copy; 2023-2026 1503Dev. All rights reserved.
      </p>
    </div>
  </body>
</html>

<style>
  @font-face {
    font-family: "Bunya Light";
    src: url("https://static.1503dev.top/font/bunya/1.0/bunya-light.ttf")
      format("truetype");
    font-display: swap;
  }
  /* 基础与现代暗黑配色方案 (VitePress 核心变量复刻) */
  :root {
    --vp-c-brand: #3eaf7c;
    --vp-c-brand-light: #4abf8a;
    --vp-c-bg: #1e1e20;
    --vp-c-bg-soft: #252529;
    --vp-c-bg-mute: #2f2f35;
    --vp-c-text-1: rgba(255, 255, 255, 0.92);
    --vp-c-text-2: rgba(255, 255, 255, 0.6);
    --font-sans:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu,
      Cantarell, "Fira Sans", "Droid Sans", "Helvetica Neue", sans-serif;
  }

  body {
    background-color: var(--vp-c-bg);
    color: var(--vp-c-text-1);
    font-family: var(--font-sans);
    margin: 0;
    padding: 0;
    -webkit-font-smoothing: antialiased;
  }

  .theme-wrapper {
    max-width: 1152px;
    margin: 0 auto;
    padding: 64px 24px;
  }

  /* Hero 样式 */
  .hero {
    text-align: center;
    padding: 48px 0;
  }
  .hero-name {
    font-size: 96px;
    font-weight: 700;
    letter-spacing: -1px;
    margin: 0;
    background: linear-gradient(315deg, #42d392 25%, #647eff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: 'Bunya Light', var(--font-sans);
  }
  .hero-tagline {
    font-size: 24px;
    color: var(--vp-c-text-2);
    margin: 16px 0 32px;
  }
  .actions {
    display: flex;
    justify-content: center;
    gap: 12px;
  }
  .action-btn {
    display: inline-block;
    border-radius: 20px;
    padding: 0 20px;
    line-height: 38px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s;
  }
  .action-btn.brand {
    background-color: var(--vp-c-brand);
    color: #fff;
  }
  .action-btn.brand:hover {
    background-color: var(--vp-c-brand-light);
  }
  .action-btn.alt {
    background-color: var(--vp-c-bg-mute);
    color: var(--vp-c-text-1);
  }
  .action-btn.alt:hover {
    background-color: #3f3f46;
  }

  /* Features 样式 */
  .features {
    margin-top: 64px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(256px, 1fr));
    gap: 24px;
  }
  .feature-card {
    background-color: var(--vp-c-bg-soft);
    border: 1px solid var(--vp-c-bg-soft);
    padding: 24px;
    border-radius: 12px;
    height: 100%;
  }
  .feature-title {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px 0;
  }
  .feature-details {
    font-size: 14px;
    color: var(--vp-c-text-2);
    margin: 0;
    line-height: 22px;
  }

  /* 结构标题 */
  .section-container {
    margin-top: 96px;
  }
  .section-container h2 {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 24px;
    border-bottom: 1px solid var(--vp-c-bg-mute);
    padding-bottom: 8px;
  }

  /* Team & Projects 复刻网格 */
  .team-grid {
    display: grid;
    gap: 24px;
  }
  .team-grid.size-small {
    grid-template-columns: repeat(auto-fit, minmax(224px, 1fr));
  }
  .team-grid.size-medium {
    grid-template-columns: repeat(auto-fit, minmax(256px, 1fr));
  }

  .member-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background-color: var(--vp-c-bg-soft);
    padding: 16px;
    border-radius: 12px;
  }
  .size-small .avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
  }
  .size-medium .avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
  }

  .member-card .info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .member-card .name {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
  }
  .member-card .title {
    font-size: 13px;
    color: var(--vp-c-text-2);
    margin: 0;
  }

  .member-card .links {
    display: flex;
    gap: 12px;
    margin-top: 4px;
  }
  .member-card .links a {
    color: var(--vp-c-text-2);
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
  }
  .member-card .links a:hover {
    color: var(--vp-c-text-1);
  }

  /* 蒙版图标支持 */
  :global(.vpi-social-icon),
  :global(.vpi-social-minebbs) {
    mask: var(--icon) no-repeat;
    -webkit-mask: var(--icon) no-repeat;
    mask-size: 100% 100%;
    -webkit-mask-size: 100% 100%;
  }
  .footer {
    text-align: center;
    padding: 24px 0;
    color: var(--vp-c-text-2);
  }
</style>
